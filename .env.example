# MAI_transcribe — Environment Variables
# Copy this file to .env and fill in your values.
#
# AUTHENTICATION
# All Azure services use DefaultAzureCredential (managed identity in Azure,
# Azure CLI / VS Code locally).  No API keys or connection strings required.
#
# OPTIONAL FALLBACK: If you set a key/connection-string variable below,
# it will be used instead of managed identity — handy for local dev when
# you haven't logged in via `az login` yet.

# Azure Speech Services (used by: azure_stt_batch, azure_stt_fast)
# AZURE_SPEECH_KEY=              # optional fallback — leave unset to use managed identity
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_ENDPOINT=           # Custom subdomain (required for managed identity)
                                  # e.g. https://my-resource.cognitiveservices.azure.com/

# MAI-Transcribe-1 (separate resource/region from standard STT)
# MAI_SPEECH_KEY=                # optional fallback
MAI_SPEECH_REGION=eastus
MAI_SPEECH_ENDPOINT=             # e.g. https://foundry-mai-transcribe.cognitiveservices.azure.com/

# Azure Blob Storage (used by: azure_stt_batch only)
AZURE_STORAGE_ACCOUNT_NAME=      # e.g. mystorageaccount (required for managed identity blob access)
# AZURE_STORAGE_CONNECTION_STRING= # optional fallback — leave unset to use managed identity
AZURE_STORAGE_CONTAINER_NAME=transcription-audio

# Azure OpenAI (used by: aoai_transcribe)
# AZURE_OPENAI_API_KEY=          # optional fallback — leave unset to use managed identity
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-transcribe

# Azure Speech — Whisper (batch transcription via Speech resource)
# If empty, the Whisper base model is auto-discovered from the Speech resource.
# AZURE_WHISPER_MODEL_ID=

# Voxtral Mini via Azure Foundry (used by: voxtral)
VOXTRAL_ENDPOINT_URL=
# VOXTRAL_ENDPOINT_KEY=          # optional fallback — leave unset to use managed identity
